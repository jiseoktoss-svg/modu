# Supabase — 서버에서만 사용한다. SUPABASE_SECRET_KEY 는 절대 브라우저에 노출하지 않는다.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SECRET_KEY=

# 선택: 공유 링크 절대 경로 생성에 사용한다. 없으면 요청 헤더 기반으로 추정한다.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 호환 목적 fallback — SUPABASE_SECRET_KEY 가 없을 때만 사용된다.
SUPABASE_SERVICE_ROLE_KEY=

# 개발 모드에서는 Supabase 값이 비어 있으면 자동으로 .modu-local-db.json 파일 저장소를 사용한다.

# 선택: 화면 우상단에 디버그용 페이지 번호 뱃지를 표시한다(개발 소통용). 제출/배포에서는 설정하지 않는다.
NEXT_PUBLIC_SHOW_DEBUG_TAG=
